# =========================
# EcoMetricAI .gitignore
# Root Project: ecometricAi
# =========================

# -------------------------
# OS Files
# -------------------------
.DS_Store
Thumbs.db

# -------------------------
# Logs
# -------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -------------------------
# Environment Variables
# -------------------------
.env
*.env

# =========================
# BACKEND (FastAPI)
# =========================

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
ENV/
.venv/

# FastAPI / Python tools
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# SQLite DB
*.db
*.sqlite3

# SQLAlchemy cache
instance/

# VS Code
.vscode/

# JetBrains
.idea/

# =========================
# FRONTEND (React + Vite)
# =========================

frontend/node_modules/
frontend/dist/
frontend/build/

# Vite
frontend/.vite/

# React env
frontend/.env

# =========================
# CYPRESS
# =========================

frontend/cypress/videos/
frontend/cypress/screenshots/
frontend/cypress/downloads/

# Cypress cache
Cypress/screenshots/
Cypress/videos/

# =========================
# Misc
# =========================

*.swp
*.swo
*.tmp
*.temp